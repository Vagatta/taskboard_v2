# Variables de entorno para Taskboard

# Supabase
REACT_APP_SUPABASE_URL=tu_url_de_supabase
REACT_APP_SUPABASE_ANON_KEY=tu_clave_anonima_de_supabase

# Configuración SMTP del backend para invitaciones por correo
TASKBOARD_SMTP_HOST=smtp.resend.com
TASKBOARD_SMTP_PORT=587
TASKBOARD_SMTP_USER=resend
TASKBOARD_SMTP_PASS=tu_api_key_de_resend
TASKBOARD_SMTP_FROM_EMAIL=noreply@kuchenhouse.es
TASKBOARD_SMTP_FROM_NAME=Taskboard

# URL base de la aplicación
TASKBOARD_BASE_URL=http://localhost/taskboard_v2
REACT_APP_BASE_URL=http://localhost/taskboard_v2
REACT_APP_API_BASE_URL=http://localhost/taskboard_v2
